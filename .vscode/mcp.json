{
	"servers": {
		"supabase": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp?project_ref=adaswccwicyubhzfwpoi"
		},
		"hf-mcp-server": {
			"url": "https://huggingface.co/mcp?login",
			"type": "http"
		},
		"cloudinary-asset-mgmt": {
			"type": "http",
			"url": "https://asset-management.mcp.cloudinary.com/mcp",
			"headers": {
				"cloudinary-url": "cloudinary://${env:CLOUDINARY_API_KEY}:${env:CLOUDINARY_API_SECRET}@${env:CLOUDINARY_CLOUD_NAME}"
			}
		},
		"cloudinary-env-config": {
			"type": "http",
			"url": "https://environment-config.mcp.cloudinary.com/mcp",
			"headers": {
				"cloudinary-cloud-name": "${env:CLOUDINARY_CLOUD_NAME}",
				"cloudinary-api-key": "${env:CLOUDINARY_API_KEY}",
				"cloudinary-api-secret": "${env:CLOUDINARY_API_SECRET}"
			}
		},
		"cloudinary-smd": {
			"type": "http",
			"url": "https://structured-metadata.mcp.cloudinary.com/mcp",
			"headers": {
				"cloudinary-url": "cloudinary://${env:CLOUDINARY_API_KEY}:${env:CLOUDINARY_API_SECRET}@${env:CLOUDINARY_CLOUD_NAME}"
			}
		}
	},
	"inputs": []
}